# ============================================================
# AI 私人健康助手 — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# 数据库 (SQLite 本地文件)
DATABASE_URL="file:./dev.db"

# 后端端口
PORT=3001

# --- AI Chat Providers (至少配置一个) ---

# Claude (Anthropic) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Gemini (Google) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- STT Providers (至少配置一个，默认使用本地 faster-whisper) ---

# Deepgram — https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# --- 外部数据 API (可选) ---

# USDA FoodData Central — https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# ExerciseDB (RapidAPI) — https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
EXERCISEDB_API_KEY=

# --- TTS Provider ---
# MIMO-v2.5-tts
MIMO_TTS_API_KEY=
MIMO_TTS_URL=https://api.xiaomimimo.com/v1
